{
  "name": "contract-review-assistant",
  "version": "3.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "description": "合同审查助手 - Word Add-in with AI-powered contract review",
  "author": "sublatesublate-design",
  "contributors": [
    "Antigravity (Google Deepmind)"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w addin\" \"npm run dev -w server\"",
    "build": "npm run build -w addin && npm run build -w server",
    "build:addin": "npm run build -w addin",
    "build:server": "npm run build -w server",
    "build:desktop": "npm run build:exe -w desktop",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present",
    "start:word": "office-addin-debugging start manifest.xml desktop",
    "stop:word": "office-addin-debugging stop manifest.xml"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "iconv-lite": "^0.7.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
