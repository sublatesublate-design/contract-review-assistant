# 依赖
node_modules/
.pnpm-debug.log*

# 构建输出
dist/
build/
*.js.map
*.d.ts

# 系统与开发环境
.DS_Store
Thumbs.db
.env
*.local
.claude/
.vscode/
.idea/

# 临时文件与备份
*.tmp
*.bak
*.swp
*.swo

# 日志文件 (忽略所有根目录及包内的 txt / log)
*.log
*.txt
!README.txt
!LICENSE.txt
!packages/**/README.txt

# 资源与素材 (忽略根目录下的图片，仅保留包内 assets)
*.png
*.jpg
*.jpeg
*.gif
!packages/**/assets/*.png
!packages/**/assets/*.jpg
!public/assets/*.png
!public/assets/*.jpg

# Markdown (忽略根目录下的非核心 md 文件)
*.md
!README.md
!CODE_OF_CONDUCT.md
!CONTRIBUTING.md
!packages/**/*.md

# 脚本 (仅保留核心启动脚本)
*.bat
!启动.bat
!fix_registry.bat
!packages/**/*.bat

# 审查辅助文件
findings.md
progress.md
task_plan.md
review_report.md
ts_errors.txt

# Local generated outputs and scratch files
output/
tmp/
packages/server/scripts/__pycache__/
packages/desktop/out/*.exe
