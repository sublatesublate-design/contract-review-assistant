{
  "name": "server",
  "version": "3.0.0",
  "private": true,
  "description": "合同审查助手 - 后端 API 服务",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "node --test --import tsx src/services/litigation/litigation.test.ts",
    "test:litigation": "node --test --import tsx src/services/litigation/litigation.test.ts",
    "generate:templates": "python scripts/generate_official_template_assets.py",
    "normalize:templates": "node scripts/normalize-template-assets.mjs",
    "lint": "eslint src --ext .ts",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "openai": "^4.24.7",
    "pizzip": "^3.2.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "rimraf": "^5.0.5",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
