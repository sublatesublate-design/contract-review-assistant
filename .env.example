# ==============================================
# 合同审查助手 - 环境变量配置模板
# 复制此文件为 .env 并填入真实值
# ==============================================

# ----- 服务端口 -----
PORT=3001
ADDIN_PORT=3000

# ----- Anthropic Claude -----
# 获取地址: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ----- OpenAI -----
# 获取地址: https://platform.openai.com/api-keys
OPENAI_API_KEY=
# 如使用 OpenAI 兼容接口（如 Azure OpenAI），修改此值
OPENAI_BASE_URL=https://api.openai.com/v1

# ----- Ollama（本地部署）-----
# 默认地址，无需修改
OLLAMA_BASE_URL=http://localhost:11434

# ----- 审查配置 -----
# 默认使用的 AI 提供商: claude / openai / ollama
DEFAULT_PROVIDER=claude
# 最大输入 Token 数（超出将截断）
MAX_INPUT_TOKENS=100000
